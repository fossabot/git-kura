{
  "name": "git-kura",
  "image": "mcr.microsoft.com/devcontainers/go:1.26-trixie",
  "workspaceFolder": "/workspaces/git-kura",
  "remoteUser": "vscode",
  "runArgs": ["--init"],
  "postCreateCommand": "bash -lc 'git config --global --add safe.directory /workspaces/git-kura && if [ -f go.mod ]; then go mod download; fi && git --version && go version'",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "EditorConfig.EditorConfig"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n",
        "go.useLanguageServer": true,
        "go.formatTool": "gofmt"
      }
    }
  }
}
